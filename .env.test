# ── HedgeIQ test environment variables ────────────────────────────────────────
# Used by pytest (backend) and Playwright (E2E) test runs.
# This file is safe to commit — it contains only test credentials.

# Backend
DATABASE_URL=sqlite:///./test_hedgeiq.db
SECRET_KEY=test-secret-key-minimum-32-chars-xxxxxx
ANTHROPIC_API_KEY=test-anthropic-key
POLYGON_API_KEY=test-polygon-key
SNAPTRADE_CLIENT_ID=test-client-id
SNAPTRADE_CONSUMER_KEY=test-consumer-key
SNAPTRADE_PERSONAL_USER_ID=test-snaptrade-user
SNAPTRADE_USER_SECRET=00000000-0000-0000-0000-000000000000
ADMIN_EMAIL=admin@test.hedgeiq.com
ADMIN_PASSWORD=AdminPass123!
ENVIRONMENT=test
CHROMADB_PATH=./data/test_chroma_cache
