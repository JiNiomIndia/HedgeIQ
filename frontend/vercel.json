{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://hedgeiq-production.up.railway.app/api/:path*"
    },
    {
      "source": "/presentation",
      "destination": "/presentation/index.html"
    },
    {
      "source": "/wiki",
      "destination": "/wiki/index.html"
    },
    {
      "source": "/wiki/:slug((?!.*\\.).+)",
      "destination": "/wiki/:slug.html"
    },
    {
      "source": "/help",
      "destination": "/help/index.html"
    },
    {
      "source": "/help/:slug((?!.*\\.).+)",
      "destination": "/help/:slug.html"
    },
    {
      "source": "/presentation/:path*",
      "destination": "/presentation/:path*"
    },
    {
      "source": "/wiki/:path*",
      "destination": "/wiki/:path*"
    },
    {
      "source": "/help/:path*",
      "destination": "/help/:path*"
    },
    {
      "source": "/((?!api|presentation|wiki|help|assets).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
