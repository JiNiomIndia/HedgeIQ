{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "HedgeIQ design tokens. Single source of truth for theme generation. Session 1 of Phase 2 reads this file and produces frontend/src/lib/theme.css with CSS variables.",
  "$version": "0.1.0",
  "$instructions": "Replace every placeholder value below with the corresponding value from your Claude Design file. Leave the structure and token names intact — Phase 2 code generation relies on these exact keys.",

  "color": {
    "brand": {
      "primary":    { "$value": "#00D4FF", "$description": "Primary accent — CTAs, links, highlights" },
      "primaryHover": { "$value": "#00B8DB" },
      "secondary":  { "$value": "#8B5CF6", "$description": "Secondary accent for variety" }
    },
    "semantic": {
      "success":    { "$value": "#00FF88", "$description": "Positive P&L, buy prices, uptrend" },
      "danger":     { "$value": "#FF4466", "$description": "Negative P&L, sell prices, downtrend" },
      "warn":       { "$value": "#FFC400", "$description": "Warnings, ATM highlight, near-expiry" },
      "info":       { "$value": "#00D4FF" }
    },
    "theme": {
      "dark": {
        "bg":         { "$value": "#0A0E1A" },
        "bgElevated": { "$value": "#131929" },
        "bgHover":    { "$value": "#1F2937" },
        "fg":         { "$value": "#E8EAF0" },
        "fgMuted":    { "$value": "#9CA3AF" },
        "fgSubtle":   { "$value": "#4B5563" },
        "border":     { "$value": "#1F2937" },
        "borderStrong": { "$value": "#374151" }
      },
      "light": {
        "bg":         { "$value": "#FFFFFF" },
        "bgElevated": { "$value": "#F9FAFB" },
        "bgHover":    { "$value": "#F3F4F6" },
        "fg":         { "$value": "#111827" },
        "fgMuted":    { "$value": "#4B5563" },
        "fgSubtle":   { "$value": "#9CA3AF" },
        "border":     { "$value": "#E5E7EB" },
        "borderStrong": { "$value": "#D1D5DB" }
      }
    }
  },

  "space": {
    "0":  { "$value": "0" },
    "1":  { "$value": "4px" },
    "2":  { "$value": "8px" },
    "3":  { "$value": "12px" },
    "4":  { "$value": "16px" },
    "5":  { "$value": "20px" },
    "6":  { "$value": "24px" },
    "8":  { "$value": "32px" },
    "10": { "$value": "40px" },
    "12": { "$value": "48px" },
    "16": { "$value": "64px" }
  },

  "radius": {
    "none": { "$value": "0" },
    "sm":   { "$value": "4px" },
    "md":   { "$value": "8px" },
    "lg":   { "$value": "12px" },
    "xl":   { "$value": "16px" },
    "full": { "$value": "9999px" }
  },

  "shadow": {
    "sm": { "$value": "0 1px 2px rgba(0,0,0,0.1)" },
    "md": { "$value": "0 4px 8px rgba(0,0,0,0.2)" },
    "lg": { "$value": "0 12px 24px rgba(0,0,0,0.35)" }
  },

  "type": {
    "family": {
      "sans":  { "$value": "'Inter', system-ui, -apple-system, sans-serif" },
      "mono":  { "$value": "'JetBrains Mono', 'Menlo', monospace" },
      "numeric": { "$value": "'Inter', system-ui", "$description": "Must support tabular-nums" }
    },
    "size": {
      "xs":   { "$value": "11px" },
      "sm":   { "$value": "12px" },
      "base": { "$value": "14px" },
      "md":   { "$value": "16px" },
      "lg":   { "$value": "18px" },
      "xl":   { "$value": "22px" },
      "2xl":  { "$value": "28px" },
      "3xl":  { "$value": "36px" }
    },
    "weight": {
      "regular": { "$value": 400 },
      "medium":  { "$value": 500 },
      "bold":    { "$value": 700 }
    },
    "leading": {
      "tight":  { "$value": 1.2 },
      "normal": { "$value": 1.5 },
      "loose":  { "$value": 1.75 }
    }
  },

  "breakpoint": {
    "mobile":  { "$value": "640px" },
    "tablet":  { "$value": "768px" },
    "laptop":  { "$value": "1024px" },
    "desktop": { "$value": "1440px" },
    "wide":    { "$value": "1920px" }
  },

  "motion": {
    "duration": {
      "instant": { "$value": "100ms" },
      "fast":    { "$value": "200ms" },
      "normal":  { "$value": "300ms" },
      "slow":    { "$value": "500ms" }
    },
    "easing": {
      "standard": { "$value": "cubic-bezier(0.4, 0, 0.2, 1)" },
      "accelerate": { "$value": "cubic-bezier(0.4, 0, 1, 1)" },
      "decelerate": { "$value": "cubic-bezier(0, 0, 0.2, 1)" }
    }
  }
}
