# ── HedgeIQ environment variables ─────────────────────────────────────────────
# Copy to .env and fill in your real values. Never commit .env.

# Anthropic Claude API (get from console.anthropic.com → your funded workspace)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Polygon.io (free tier works; Starter plan needed for live options chain)
POLYGON_API_KEY=your_polygon_key

# SnapTrade (register at app.snaptrade.com/developers)
SNAPTRADE_CLIENT_ID=your_client_id
SNAPTRADE_CONSUMER_KEY=your_consumer_key
SNAPTRADE_PERSONAL_USER_ID=your_snaptrade_user_id
SNAPTRADE_USER_SECRET=your_user_secret_uuid

# JWT signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_random_64_char_hex_string

# SQLite (local) — swap for PostgreSQL URL on Railway
DATABASE_URL=sqlite:///./hedgeiq.db

# ChromaDB vector cache
CHROMADB_PATH=./data/chroma_cache

ENVIRONMENT=development

# Admin login (single-user v0.1)
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=your_secure_password
SNAPTRADE_USER_SECRET=
