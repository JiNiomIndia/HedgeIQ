# ── Stage 1: builder ──────────────────────────────────────────────────────────
FROM python:3.12-slim AS builder

WORKDIR /app

# Install build deps for native wheels (chromadb, cryptography, hnswlib)
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential gcc g++ libffi-dev && \
    rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

# ── Stage 2: runtime ──────────────────────────────────────────────────────────
FROM python:3.12-slim

WORKDIR /app

# Runtime system libraries needed by chromadb (hnswlib uses OpenMP + libstdc++)
RUN apt-get update && apt-get install -y --no-install-recommends \
    libgomp1 libstdc++6 && \
    rm -rf /var/lib/apt/lists/*

# Copy installed packages from builder
COPY --from=builder /usr/local/lib/python3.12 /usr/local/lib/python3.12
COPY --from=builder /usr/local/bin /usr/local/bin

# Copy application code
COPY backend/ ./backend/
COPY alembic.ini ./alembic.ini

# Create data directory for ChromaDB cache and SQLite
RUN mkdir -p /app/data/chroma_cache

# Non-root user for security
RUN useradd -m -u 1001 hedgeiq && chown -R hedgeiq /app
USER hedgeiq

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/health')"

CMD ["uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "8000"]
